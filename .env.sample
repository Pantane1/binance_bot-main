# ============================================
# Trading AI - Environment Variables Sample
# ============================================
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control!

# ============================================
# Binance API Credentials (REQUIRED)
# ============================================
# Get your API keys from: https://www.binance.com/en/my/settings/api-management
# For testing, use testnet: https://testnet.binance.vision/
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ============================================
# Twitter API Credentials (OPTIONAL)
# ============================================
# Required for social media sentiment analysis
# Get your keys from: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# ============================================
# Reddit API Credentials (OPTIONAL)
# ============================================
# Required for Reddit sentiment analysis
# Create app at: https://www.reddit.com/prefs/apps
# Note: Reddit can work with minimal credentials for read-only access
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=TradingAI/1.0

# ============================================
# Blockchain Explorer API Keys (OPTIONAL)
# ============================================
# Required for wallet analysis features
# Etherscan: https://etherscan.io/apis
# Blockchain.info: https://www.blockchain.com/api
ETHERSCAN_API_KEY=your_etherscan_api_key
BLOCKCHAIN_API_KEY=your_blockchain_api_key

# ============================================
# Notes
# ============================================
# - Binance API keys are REQUIRED for trading
# - Social media APIs are OPTIONAL but recommended for better predictions
# - Blockchain APIs are OPTIONAL for advanced wallet analysis
# - All values should be kept secret and never committed to git
# - Use testnet keys for initial testing